# SQLite for Prisma (invoices / fulfillment / leads — not catalog)
DATABASE_URL="file:./dev.db"

GCLOUD_PROJECT=photography-964f5

# Local redirects (Cloud Run sets photography-964f5.web.app)
PUBLIC_HOST=localhost:3000

# Optional: staff email notification on buyer invoice-request submit (src/lib/email.ts,
# src/lib/notify.ts). Same provider as the legacy Cloud Functions (functions/salesPortal.js).
# Without SENDGRID_API_KEY, notify is a no-op (logged) and never blocks the submit.
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=info@itemiq.ai
# Fallback recipients if no salesPortalStaff accounts / settings notifyEmails are set yet.
# STAFF_NOTIFICATION_EMAILS=ops@example.com,manager@example.com

# Daily job auth for POST /api/cron/expire-bundles (auto-archive lots ≥14 days +
# timeout invoice requests ≥7 days). Already set on Cloud Run production.
# CRON_SECRET=generate-a-long-random-string
# Optional Firebase Storage bucket override (default: photography-964f5.firebasestorage.app)
# FIREBASE_STORAGE_BUCKET=photography-964f5.firebasestorage.app
