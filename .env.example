# SQLite for Prisma (invoices / fulfillment / leads — not catalog)
DATABASE_URL="file:./dev.db"

GCLOUD_PROJECT=photography-964f5

# Local redirects (Cloud Run sets photography-964f5.web.app)
PUBLIC_HOST=localhost:3000

# Local Firestore auth — use a service account key so login doesn't break when
# `gcloud auth application-default` expires (invalid_rapt).
# 1. Create key: gcloud iam service-accounts keys create .secrets/firebase-admin.json \
#      --iam-account=firebase-adminsdk-fbsvc@photography-964f5.iam.gserviceaccount.com \
#      --project photography-964f5
# 2. Point at it (path relative to luxe-supply-wholesale/):
# GOOGLE_APPLICATION_CREDENTIALS=.secrets/firebase-admin.json
# Never commit .secrets/ or the JSON key.

# Optional: inline JSON instead of a file (same SA). Prefer the file path above.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional: staff email notification on buyer invoice-request submit (src/lib/email.ts,
# src/lib/notify.ts). Same provider as the legacy Cloud Functions (functions/salesPortal.js).
# Without SENDGRID_API_KEY, notify is a no-op (logged) and never blocks the submit.
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=info@luxesupply.co
# Fallback recipients if no salesPortalStaff accounts / settings notifyEmails are set yet.
# STAFF_NOTIFICATION_EMAILS=ops@example.com,manager@example.com

# "Sign in with Google" on both sign-in pages (buyer storefront + staff portal).
# Same Auth.js-style redirect as hq.eelolive.com: button → /api/auth/google →
# Google → /api/auth/callback/google → our __session cookie.
#
# GCP console → APIs & Services → Credentials → OAuth 2.0 Web client:
#   Authorized redirect URIs (must match exactly):
#     http://localhost:3000/api/auth/callback/google
#     https://photography-964f5.web.app/api/auth/callback/google
#     https://wholesale.luxesupply.co/api/auth/callback/google
#     https://wholesaleportal.luxesupply.co/api/auth/callback/google
# GOOGLE_OAUTH_CLIENT_ID=1234567890-abc.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...
# Optional: restrict staff Google accounts to one Workspace domain (hd=).
# GOOGLE_OAUTH_HD_STAFF=luxesupply.co
# Optional alias kept for older deploys (same value as GOOGLE_OAUTH_CLIENT_ID):
# NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=1234567890-abc.apps.googleusercontent.com

# Daily job auth for POST /api/cron/expire-bundles (auto-archive lots ≥14 days +
# timeout invoice requests ≥7 days). Already set on Cloud Run production.
# CRON_SECRET=generate-a-long-random-string
# Optional Firebase Storage bucket override (default: photography-964f5.firebasestorage.app)
# FIREBASE_STORAGE_BUCKET=photography-964f5.firebasestorage.app

# Manager TOTP 2FA — encrypts authenticator secrets at rest (AES-GCM).
# Prefer a dedicated key in production; falls back to AUTH_SECRET, then a
# local-only default (not for prod).
# TOTP_ENCRYPTION_KEY=generate-a-long-random-string
# AUTH_SECRET=optional-shared-secret-also-used-for-totp-if-TOTP_ENCRYPTION_KEY-unset
