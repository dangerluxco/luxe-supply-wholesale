{
  "hosting": [
    {
      "site": "luxe-wholesale",
      "public": "hosting-public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        {
          "source": "/",
          "destination": "/wholesale",
          "type": 302
        }
      ],
      "rewrites": [
        {
          "source": "/wholesaleportal",
          "run": {
            "serviceId": "luxe-wholesale-portal",
            "region": "us-central1"
          }
        },
        {
          "source": "/wholesaleportal/**",
          "run": {
            "serviceId": "luxe-wholesale-portal",
            "region": "us-central1"
          }
        },
        {
          "source": "/wholesale",
          "run": {
            "serviceId": "luxe-wholesale-portal",
            "region": "us-central1"
          }
        },
        {
          "source": "/wholesale/**",
          "run": {
            "serviceId": "luxe-wholesale-portal",
            "region": "us-central1"
          }
        },
        {
          "source": "/curation",
          "run": {
            "serviceId": "luxe-wholesale-portal",
            "region": "us-central1"
          }
        },
        {
          "source": "/curation/**",
          "run": {
            "serviceId": "luxe-wholesale-portal",
            "region": "us-central1"
          }
        },
        {
          "source": "/fulfillment",
          "run": {
            "serviceId": "luxe-wholesale-portal",
            "region": "us-central1"
          }
        },
        {
          "source": "/fulfillment/**",
          "run": {
            "serviceId": "luxe-wholesale-portal",
            "region": "us-central1"
          }
        },
        {
          "source": "/_next/**",
          "run": {
            "serviceId": "luxe-wholesale-portal",
            "region": "us-central1"
          }
        },
        {
          "source": "/api",
          "run": {
            "serviceId": "luxe-wholesale-portal",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/**",
          "run": {
            "serviceId": "luxe-wholesale-portal",
            "region": "us-central1"
          }
        },
        {
          "source": "/favicon.ico",
          "run": {
            "serviceId": "luxe-wholesale-portal",
            "region": "us-central1"
          }
        },
        {
          "source": "/favicon.png",
          "run": {
            "serviceId": "luxe-wholesale-portal",
            "region": "us-central1"
          }
        },
        {
          "source": "/icon.png",
          "run": {
            "serviceId": "luxe-wholesale-portal",
            "region": "us-central1"
          }
        },
        {
          "source": "/apple-icon.png",
          "run": {
            "serviceId": "luxe-wholesale-portal",
            "region": "us-central1"
          }
        },
        {
          "source": "/apple-touch-icon.png",
          "run": {
            "serviceId": "luxe-wholesale-portal",
            "region": "us-central1"
          }
        },
        {
          "source": "/luxe-supply-logo.png",
          "run": {
            "serviceId": "luxe-wholesale-portal",
            "region": "us-central1"
          }
        }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "private, no-cache, no-store, max-age=0, must-revalidate"
            }
          ]
        },
        {
          "source": "/_next/static/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        },
        {
          "source": "/_next/image",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=86400, stale-while-revalidate=2592000"
            }
          ]
        }
      ]
    },
